{
  "name": "qq-farm-bot-web",
  "type": "module",
  "version": "4.5.54",
  "private": true,
  "scripts": {
    "sync:release-notes": "node ../scripts/utils/sync-help-release-notes.js",
    "dev": "pnpm sync:release-notes && vite",
    "build": "pnpm sync:release-notes && vue-tsc -b && vite build",
    "build:runtime": "pnpm sync:release-notes && vue-tsc -b && WEB_DIST_DIR=dist-runtime vite build",
    "farm-tools:sync": "python3 public/nc_local_version/scraper.py",
    "check:ui-appearance": "node scripts/check-ui-appearance.mjs",
    "lint:check": "eslint \"src/**/*.{ts,vue}\" \"__tests__/**/*.mjs\" \"eslint.config.js\"",
    "lint": "eslint \"src/**/*.{ts,vue}\" --fix",
    "preview": "vite preview",
    "test:e2e:help-center": "pnpm build:runtime && playwright test e2e/help-center.regression.spec.ts",
    "test:e2e:system-update": "pnpm build:runtime && playwright test e2e/system-update-announcement-sync.spec.ts e2e/system-update-cluster-flow.spec.ts",
    "test:unit": "node --test --experimental-strip-types __tests__/*.test.mjs",
    "test:regression": "pnpm sync:release-notes && pnpm exec vue-tsc -b --pretty false --force && pnpm test:unit && pnpm build:runtime"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.5",
    "echarts": "^6.0.0",
    "marked": "^4.3.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.25",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@iconify-json/carbon": "^1.2.18",
    "@iconify-json/fa-solid": "^1.2.2",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/nprogress": "^0.2.3",
    "@unocss/eslint-plugin": "^66.5.12",
    "@unocss/reset": "^66.5.12",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^1.4.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "typescript": "~5.9.3",
    "unocss": "^66.5.12",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "^3.1.5"
  }
}
