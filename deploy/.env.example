# =====================================================
# QQ 农场智能助手 - 环境变量配置模板
# =====================================================
# 说明：复制为 .env 并修改下方变量后运行 docker compose up -d 即可启动
# 集成栈默认包含 App + MySQL + Redis + ipad860
# =====================================================

# ========== 必改项 ==========

# Web 管理后台密码（登录用）
# 首次部署时会自动创建 admin 管理员账号并使用该密码
ADMIN_PASSWORD=qq007qq008

# 部署实例名称。用于隔离容器名、当前版本链接和更新代理服务名。
# 同一台机器上跑多套环境时，请为每套环境指定不同值，例如 qq-farm-2400 / qq-farm-2500。
STACK_NAME=qq-farm

# ========== 对外访问 ==========

# Web 对外端口（默认 3080）
WEB_PORT=3080

# Cookie 安全模式：auto / true / false
# 反向代理 HTTPS 场景建议保持 auto
COOKIE_SECURE=auto

# 允许跨域的前端来源，多个用英文逗号分隔
# 例如: http://10.31.0.194:3080,http://example.com
CORS_ORIGINS=

# 可选：显式指定 JWT_SECRET；留空时程序会自动生成并持久化到 data/.jwt-secret
JWT_SECRET=

# ========== 集群 / 分布式 ==========

# 运行角色：standalone / master / worker
APP_ROLE=standalone

# 多实例共享网络名称。master / worker / 共享服务会通过这个网络互相访问。
SHARED_DOCKER_NETWORK=qq-farm-shared
# 设为 true 时把共享网络当作外部网络复用，适合跨栈切换/滚动更新测试。
SHARED_DOCKER_NETWORK_EXTERNAL=false

# Worker 连接 Master 使用。master/standalone 可留空。
MASTER_URL=
WORKER_TOKEN=default_cluster_token
WORKER_NODE_ID=
WORKER_HEARTBEAT_INTERVAL_MS=15000

# ========== 镜像配置 ==========

# 可选：自定义镜像版本/仓库
# fresh-install.sh / update-app.sh 会依次尝试：
# 1) 当前 APP_IMAGE
# 2) Docker Hub: smdk000/qq-farm-bot-ui:<tag>
# 3) GHCR: ghcr.io/smdk000/qq-farm-ui-pro-max:<tag>
# 4) 本地已导入的镜像缓存
APP_IMAGE=smdk000/qq-farm-bot-ui:4.5.36
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine
IPAD860_IMAGE=smdk000/ipad860:latest

# 可选：离线镜像包路径（fresh-install.sh / update-app.sh 会自动 docker load）
# 例如: /root/qq-farm-bot-images-amd64.tar.gz
IMAGE_ARCHIVE=

# ========== MySQL 配置 ==========

MYSQL_ROOT_PASSWORD=qq007qq008
MYSQL_DATABASE=qq_farm
MYSQL_USER=qq_farm_user
MYSQL_PASSWORD=qq007qq008
MYSQL_POOL_LIMIT=100

# 默认使用当前栈内的 mysql 服务。
# 如果要让 master 读取另一套栈的数据库，可改成类似 qq-farm-2400-mysql。
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ========== Redis 配置 ==========

# 集成部署可保持为空；如需启用 Redis 密码，请与 Redis / ipad860 保持一致
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# ========== 微信扫码第三方接口 ==========

# 留空时使用程序内置默认值；如你有自己的接口配置，建议显式填写
WX_API_KEY=
WX_API_URL=
WX_APP_ID=

# 默认使用当前栈内的 ipad860 服务。
# 如果要让 master 读取另一套栈的扫码能力，可改成类似 http://qq-farm-2400-ipad860:8058
IPAD860_URL=http://ipad860:8058

# ========== 运行日志 ==========

# 日志级别（debug / info / warn / error）
LOG_LEVEL=info

# 时区（默认上海）
TZ=Asia/Shanghai
